generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  wallet_address     String              @unique
  email              String?             @unique
  created_at         DateTime            @default(now())
  portfolio          Portfolio?
  transactions       Transaction[]
  yield_distributions YieldDistribution[]
}

model Portfolio {
  user_id      String   @id
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  frag_balance Float    @default(0)
  usd_value    Float    @default(0)
  updated_at   DateTime @updatedAt
}

model Transaction {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type       String   // e.g. "DEPOSIT", "WITHDRAWAL"
  amount_usd Float
  frag_delta Float
  txn_hash   String?  @unique
  timestamp  DateTime @default(now())
}

model YieldDistribution {
  id             String   @id @default(uuid())
  user_id        String
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  amount         Float
  distributed_at DateTime @default(now())
  txn_hash       String?  @unique
}
